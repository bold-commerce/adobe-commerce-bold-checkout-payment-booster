<?php
use Magento\Framework\View\Element\Template;
use Bold\CheckoutPaymentBooster\ViewModel\ExpressPay;

/** @var Template $block */

/** @var ExpressPay $expressPayViewModel */
$expressPayViewModel = $block->getData('express_pay_view_model');
$pageSource = $block->getData('render_page_source');
$jsLayout = $expressPayViewModel->getJsLayout();
$isCartEnabled = $expressPayViewModel->isCartWalletPayEnabled();
$isProductEnabled = $expressPayViewModel->isProductWalletPayEnabled();
$hasActiveQuote = $expressPayViewModel->hasActiveQuote();

if (!(($isCartEnabled && in_array($pageSource, ['cart'])) ||
      ($isProductEnabled && $pageSource === 'product')) ||
    !$hasActiveQuote
   ):
    return;
endif;
?>

<div id="express-pay-container" data-testid="express-pay-container">
    <div id="express-pay-buttons"></div>
</div>

<script>
    if (!window.checkoutConfig) {
        window.checkoutConfig = {};
    }

    var layout = <?=  $expressPayViewModel->getJsLayout() ?>;
    Object.assign(window.checkoutConfig, layout.checkoutConfig);
</script>

<script type="text/x-magento-init">
{
    "#express-pay-container": {
        "Bold_CheckoutPaymentBooster/js/express-pay-storefront": {
            "boldCheckoutConfig": <?= json_encode($expressPayViewModel->initConfig()) ?>,
            "pageSource": "<?= $block->escapeJs(__($pageSource)) ?>"
        }
    }
}
</script>
